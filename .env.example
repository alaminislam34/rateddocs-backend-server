# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/rateddocs_db?schema=public"

# Redis Cache/Queue Connection
REDIS_URL="redis://localhost:6379"

# Better Auth Configuration
BETTER_AUTH_SECRET="generate_a_secure_base64_secret_using_openssl_rand"
BETTER_AUTH_URL="http://localhost:5000"

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# SMTP Nodemailer Email Configuration
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="RatedDocs <noreply@rateddocs.com>"
