              "raw": "{{base_url}}/api/v1/dentists/verify-operations/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "verify-operations", "submit"]
            },
            "description": "Submit clinic operations checklists, sign medical guarantees, add custom procedures or upload a CSV. Accepts multipart/form-data with file fields 'jciCertificate', 'walkthroughVideo', 'csvFile'."
          },
          "response": []
        },
        {
          "name": "Submit Clinic Depth Docs",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinicAddress\": \"Road 11, Banani, Dhaka, Bangladesh\",\n  \"procedureDocs\": [\n    {\n      \"dentistProcedureId\": \"teeth-whitening\",\n      \"ceCertificate\": \"https://res.cloudinary.com/rateddocs/docs/ce-teeth.pdf\",\n      \"materialBrands\": \"Opalescence Go\",\n      \"invoice\": \"https://res.cloudinary.com/rateddocs/docs/invoice-teeth.pdf\",\n      \"protocolPdf\": \"https://res.cloudinary.com/rateddocs/docs/protocol-teeth.pdf\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/verify-clinic-depth/submit",
