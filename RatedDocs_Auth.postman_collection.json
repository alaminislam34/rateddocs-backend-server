            "url": {
              "raw": "{{base_url}}/api/v1/dentists/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "register"]
            },
            "description": "Register a new Dentist. Sends a 6-digit verification OTP code to the provided email address. Accepts multipart/form-data with an optional professional headshot file ('image')."
          },
          "response": []
        },
        {
          "name": "Submit Professional Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"legalName\": \"Dr. Sarah Rahman, DDS\",\n  \"yearsOfExperience\": 8,\n  \"primarySpecialty\": \"Orthodontics\",\n  \"country\": \"Bangladesh\",\n  \"city\": \"Dhaka\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/professional-data",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "professional-data"]
            },
            "description": "Submit dentist's professional background and primary specialty details."
          },
          "response": []
        },
        {
          "name": "Check Registry (Simulation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"Bangladesh\",\n  \"city\": \"Dhaka\",\n  \"registrationAuthority\": \"BMDC\",\n  \"registrationNumber\": \"DENT-887122\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/verify-license/check",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "verify-license", "check"]
            },
            "description": "Check dentist registration registry. Simulates a mismatch to enforce manual document upload."
          },
          "response": []
        },
        {
          "name": "Submit License Document",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "country",
                  "value": "Bangladesh",
                  "type": "text"
                },
                {
                  "key": "city",
                  "value": "Dhaka",
                  "type": "text"
                },
                {
                  "key": "registrationAuthority",
                  "value": "BMDC",
                  "type": "text"
                },
                {
                  "key": "registrationNumber",
                  "value": "DENT-887122",
                  "type": "text"
                },
                {
                  "key": "licenseDocument",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "profilePicture",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/verify-license/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "verify-license", "submit"]
            },
            "description": "Upload/submit physical license certificate document and professional profile picture for manual verification. Accepts multipart/form-data with fields 'licenseDocument' (file) and 'profilePicture' (file)."
          },
          "response": []
        },
