{
  "info": {
    "_postman_id": "8c459f14-34fd-4df9-8cf0-21a47321eb91",
    "name": "RatedDocs Auth Module",
    "description": "API collection for testing RatedDocs Patient and Dentist Registration, OTP Email Verification, separate logins, Google OAuth, multi-phase Dentist verification steps, and Admin reviews.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Patient Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"securepassword123\",\n  \"confirmPassword\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register/patient",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register", "patient"]
            },
            "description": "Register a new Patient. Sends a 6-digit verification OTP code to the provided email address."
          },
          "response": []
        },
        {
          "name": "Verify Email OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-email"]
            },
            "description": "Submit the 6-digit OTP code received via email to activate the user account and create their Patient profile."
          },
          "response": []
        },
        {
          "name": "Patient Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/patient",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login", "patient"]
            },
            "description": "Log in as a Patient. Sets the secure session cookies automatically. If the account is unverified, it automatically triggers a new OTP email and blocks login until verified."
          },
          "response": []
        },
        {
          "name": "Dentist Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dentist@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/dentist",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login", "dentist"]
            },
            "description": "Log in as a Dentist. Restricts access to users holding the DENTIST role."
          },
          "response": []
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/admin",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login", "admin"]
            },
            "description": "Log in as an Admin or Super Admin."
          },
          "response": []
        },
        {
          "name": "Initiate Google Login",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/google",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login", "google"]
            },
            "description": "Initiate Google OAuth login redirect flow. Access directly in browser (e.g. via anchor links) to redirect to Google's consent screen."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Invalidates the active session in the database and clears the browser's HTTP-Only session cookie."
          },
          "response": []
        }
      ]
    },
    {
