                },
                {
                  "key": "lastName",
                  "value": "Rahman",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "sarah.dentist@rateddocs.com",
                  "type": "text"
                },
                {
                  "key": "phoneNumber",
                  "value": "+8801700000000",
                  "type": "text"
                },
                {
                  "key": "gender",
                  "value": "FEMALE",
                  "type": "text"
                },
                {
                  "key": "country",
                  "value": "Bangladesh",
                  "type": "text"
                },
                {
                  "key": "referralCode",
