              "path": ["api", "v1", "dentists", "verify-clinic-depth", "submit"]
            },
            "description": "Submit clinic location maps and verification documents (CE, Material brand invoice, protocol) for selected dentist procedures."
          },
          "response": []
        },
        {
          "name": "Get Verification Progress",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/progress",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "progress"]
            },
            "description": "Retrieve current dynamic dentist verification phase and RVD progress score."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin: Get Verifications List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/admin/verifications?status=PENDING&search=Sarah&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "admin", "verifications"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                },
                {
                  "key": "search",
                  "value": "Sarah"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieve all dentist profiles and verification documents with status filter, keyword search, and pagination."
          },
          "response": []
        },
        {
          "name": "Admin: Verify License",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isApproved\": true,\n  \"note\": \"License certificate is authentic and registered.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/admin/verify-license/DENTIST_ID",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "admin", "verify-license", "DENTIST_ID"]
            },
            "description": "Review and verify/reject dentist's license manually (adds 30% to RVD). If rejecting (isApproved = false), a note containing the rejection reason must be supplied."
          },
          "response": []
        },
        {
          "name": "Admin: Verify Operations",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isApproved\": true,\n  \"note\": \"JCI certificate and guarantee details verified.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/admin/verify-operations/DENTIST_ID",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "admin", "verify-operations", "DENTIST_ID"]
            },
            "description": "Review and verify/reject dentist's operations check (adds 40% to RVD). If rejecting (isApproved = false), a note containing the rejection reason must be supplied."
          },
          "response": []
        },
        {
          "name": "Admin: Verify Clinic Depth",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isApproved\": true,\n  \"note\": \"Clinical protocols and CE certificates validated.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/dentists/admin/verify-clinic-depth/DENTIST_ID",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dentists", "admin", "verify-clinic-depth", "DENTIST_ID"]
            },
            "description": "Review and verify/reject dentist's clinic depth procedures and certificates (adds 30% to RVD). If rejecting (isApproved = false), a note containing the rejection reason must be supplied."
          },
          "response": []
        }
      ]
    }
