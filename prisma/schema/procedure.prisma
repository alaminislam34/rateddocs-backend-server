model GlobalProcedure {
  id          String     @id @default(uuid(7))
  name        String     @unique @db.VarChar(255)
  slug        String     @unique
  specialtyId String?    @map("specialty_id")
  specialty   Specialty? @relation(fields: [specialtyId], references: [id])
  isApproved  Boolean    @default(true) @map("is_approved")
  isActive    Boolean    @default(true) @map("is_active")
  isDeleted   Boolean    @default(false) @map("is_deleted")
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamp(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)

  dentistProcedures    DentistProcedure[]
  treatmentLineItems   TreatmentLineItem[]
  personalizationDatas PersonalizationData[]

  @@index([specialtyId])
  @@map("global_procedure")
}

model DentistProcedure {
  id                String          @id @default(uuid(7))
  dentistId         String          @map("dentist_id")
  dentist           Dentist         @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  globalProcedureId String          @map("global_procedure_id")
  globalProcedure   GlobalProcedure @relation(fields: [globalProcedureId], references: [id], onDelete: Cascade)
  price             Decimal         @db.Decimal(10, 2)
  notes             String?         @db.Text
  isVerified        Boolean         @default(false) @map("is_verified")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)

  clinicalProcedureDocs DentistClinicalProcedureDoc[]

  @@index([dentistId])
  @@index([globalProcedureId])
  @@map("dentist_procedure")
}

model TreatmentPlan {
  id        String          @id @default(uuid(7))
  dentistId String          @map("dentist_id")
  dentist   Dentist         @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  patientId String          @map("patient_id")
  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status    TreatmentStatus @default(DRAFT)
  notes     String?         @db.Text
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)

  lineItems TreatmentLineItem[]

  @@index([dentistId])
  @@index([patientId])
  @@map("treatment_plan")
}

model TreatmentLineItem {
  id                String          @id @default(uuid(7))
  treatmentPlanId   String          @map("treatment_plan_id")
  treatmentPlan     TreatmentPlan   @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  globalProcedureId String          @map("global_procedure_id")
  globalProcedure   GlobalProcedure @relation(fields: [globalProcedureId], references: [id], onDelete: Cascade)
  quantity          Int             @default(1)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(10, 2)
  notes             String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([treatmentPlanId])
  @@index([globalProcedureId])
  @@map("treatment_line_item")
}
