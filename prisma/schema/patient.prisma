model Patient {
  id          String    @id @default(uuid(7))
  userId      String    @unique @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber String?   @map("phone_number") @db.VarChar(25)
  country     String?   @map("country") @db.VarChar(100)
  dateOfBirth DateTime? @map("date_of_birth") @db.Date

  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamp(6)
  personalizationData PersonalizationData?
  treatmentPlans      TreatmentPlan[]

  @@index([userId])
  @@map("patient")
}

model PersonalizationData {
  id                String          @id @default(uuid(7))
  patientId         String          @unique @map("patient_id")
  patient           Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  globalProcedureId String          @map("global_procedure_id")
  globalProcedure   GlobalProcedure @relation(fields: [globalProcedureId], references: [id], onDelete: Cascade)
  budget            Decimal?        @db.Decimal(10, 2)
  travelStartDate   DateTime?       @map("travel_start_date") @db.Date
  travelEndDate     DateTime?       @map("travel_end_date") @db.Date
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([patientId])
  @@index([globalProcedureId])
  @@map("personalization_data")
}
